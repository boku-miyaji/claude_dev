{
  "remote.extensionKind": {
    // built-in をホスト側で動かす（Markdown: Open Preview 用）
    "ms-vscode.markdown-language-features": ["ui"],
    // 追加した 2 つもホストで動かす
    "yzhang.markdown-all-in-one": ["ui"],
    "shd101wyy.markdown-preview-enhanced": ["ui"]
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#e8d154",
    "activityBar.background": "#e8d154",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#138c7a",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#e8d154",
    "statusBar.background": "#e2c527",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#bda319",
    "statusBarItem.remoteBackground": "#e2c527",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#e2c527",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#e2c52799",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.remoteColor": "#e2c527",
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.expo/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "**/node_modules/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.expo/**": true,
    "**/coverage/**": true
  }
}
