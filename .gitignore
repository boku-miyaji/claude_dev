# claude - session state (DO NOT TRACK)
.claude/.claude.json
.claude/.claude.json.backup
.claude/.claude.json.corrupted.*

# claude - credentials (SENSITIVE - DO NOT TRACK)
.claude/.credentials.json
.claude/.credentials.json.*

# claude - shared settings (tracked in git for cross-server consistency)
# .claude/settings.json → tracked (hooks, plugins, base permissions)
# claude - local settings (server-specific overrides, NOT tracked)
.claude/settings.local.json
.claude/security_warnings_state_*.json
.claude/session-env/

# claude - runtime directories
.claude/projects/
.claude/todos/
.claude/ide/
.claude/statsig/
.claude/cache/
.claude/debug/
.claude/file-history/
.claude/history.jsonl
.claude/shell-snapshots/
.claude/stats-cache.json

# claude - plugins (local state)
.claude/plugins/cache/
.claude/plugins/installed_plugins.json
.claude/plugins/known_marketplaces.json
.claude/plugins/install-counts-cache.json
.claude/plugins/marketplaces/

# claude - local knowledge and plans
.claude/knowledge/
.claude/plans/

# application folder (individual app repos)
*app*
!apps/

# others
.cache
tasks*

# pj
project-*
presales-*
denso-*
circuit_diagram/

# cursor server backup - keep local but don't track
.cursor-server.bak/

# project-rikyu (tracked in separate repo)
project-review/project-rikyu-sales-proposals-poc/

# circuit diagram output (managed by circuit_diagram/.gitignore)
# circuit_diagram/output/

# company - org structure (tracked in git for cross-server sharing)
# .company/ → tracked (HD structure, departments, registry)
# .company-*/ → tracked (PJ company context, secretary)

# secrets & tokens (NEVER commit)
.config/google/credentials.json
token.json
.claude/hooks/supabase.env
