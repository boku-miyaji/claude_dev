  // ── タイミングイベント抽出（timing-calendar.ts と同じロジック） ──
  function getTimingEventsForAgenda(axisLv1, axisLv2) {
    var category = axisLv1 + '>' + axisLv2;
    var active = [];
    for (var i = 0; i < timingCalendar.length; i++) {
      var e = timingCalendar[i];
      var prepStart = ((e.month - e.prepMonthsBefore - 1 + 12) % 12) + 1;
      var inRange = false;
      if (e.prepMonthsBefore === 0) {
        inRange = e.month === currentMonth;
      } else if (prepStart <= e.month) {
        inRange = currentMonth >= prepStart && currentMonth <= e.month;
      } else {
        inRange = currentMonth >= prepStart || currentMonth <= e.month;
      }
      if (!inRange) continue;
      var hit = false;
      for (var j = 0; j < e.affectedCategories.length; j++) {
        var c = e.affectedCategories[j];
        if (c === category || category.indexOf(c.split('>')[0]) === 0) { hit = true; break; }
      }
      if (hit) active.push(e);
    }
    return active.slice(0, 2);
  }

  // ── アジェンダテーブル ──
  function renderAgendaPanel() {
    var html = renderCustomerSummary();
    html += '<div class="itd-table-wrap"><div class="itd-table-scroller">';
    html += '<table class="itd-agenda-table">';

    // thead（2段）
    html += '<thead>' +
      '<tr>' +
        '<th rowspan="2" style="width:56px"></th>' +
        '<th rowspan="2" style="width:80px">軸</th>' +
        '<th rowspan="2" style="min-width:110px">大分類</th>' +
        '<th rowspan="2" style="min-width:180px">経営アジェンダ（小分類）</th>' +
        '<th rowspan="2" style="width:50px">重要度</th>' +
        '<th rowspan="2" style="width:50px">理解度</th>' +
        '<th colspan="2" style="text-align:center">課題意識</th>' +
        '<th colspan="3" style="text-align:center">キーパーソン</th>' +
        '<th rowspan="2" style="min-width:160px">りそなの提供価値</th>' +
        '<th rowspan="2" style="min-width:160px">つながりうる商品</th>' +
        '<th rowspan="2" style="min-width:160px">対応方針</th>' +
      '</tr>' +
      '<tr>' +
        '<th style="min-width:180px">実現したいこと</th>' +
        '<th style="min-width:180px">お困りごと・理由</th>' +
        '<th style="min-width:120px">意思決定者</th>' +
        '<th style="min-width:100px">影響者</th>' +
        '<th style="min-width:100px">情報提供者</th>' +
      '</tr>' +
    '</thead>';

    // tbody — axisLv1 で rowspan を作る
    html += '<tbody>';
    // axisLv1 ごとにグループ
    var axisGroups = {};
    var axisOrder = [];
    for (var i = 0; i < agendas.length; i++) {
      var a = agendas[i];
      if (!axisGroups[a.axisLv1]) { axisGroups[a.axisLv1] = []; axisOrder.push(a.axisLv1); }
      axisGroups[a.axisLv1].push(a);
    }
    for (var g = 0; g < axisOrder.length; g++) {
      var axis = axisOrder[g];
      var list = axisGroups[axis];
      for (var k = 0; k < list.length; k++) {
        var ag = list[k];
        var events = getTimingEventsForAgenda(ag.axisLv1, ag.axisLv2);
        html += '<tr data-agenda-id="' + escHTML(ag.id) + '">';
        if (k === 0) {
          html += '<td class="itd-td-axis1" rowspan="' + list.length + '">' + escHTML(axis) + '</td>';
        }
        html += '<td class="itd-td-axis2">' + escHTML(ag.axisLv2 || '—') + '</td>';
        html += '<td class="itd-td-major">' + escHTML(ag.majorCategory) + '</td>';

        // 小分類 + 更新日 + timingタグ
        var updated = ag.updatedAt ? escHTML(ag.updatedAt.slice(0, 10)) : generatedAt;
        var tagsHTML = '';
        if (events.length > 0) {
          tagsHTML = '<div class="itd-minor-tags">' +
            events.map(function(e){
              return '<span class="itd-timing-tag itd-timing-' + escHTML(e.type) + '" title="' + escHTML(e.event + ' — ' + e.relevance) + '">📅 ' + e.month + '月 ' + escHTML(e.event) + '</span>';
            }).join('') +
          '</div>';
        }
        html += '<td class="itd-td-minor">' +
          '<span class="itd-minor-title">' + escHTML(ag.minorCategory) + '</span>' +
          '<span class="itd-minor-update">🕐 更新 ' + updated + '</span>' +
          tagsHTML +
        '</td>';

        // 重要度・理解度
        html += '<td class="itd-td-imp itd-imp-' + escHTML(ag.importance) + '">' + escHTML(ag.importance) + '</td>';
        html += '<td class="itd-td-und itd-und-' + escHTML(ag.understanding) + '">' + escHTML(ag.understanding) + '</td>';

        var srcs = ag.sources || {};

        // 実現したいこと、お困りごと（初期仮説を表示、Sharp版はモーダルへ）
        html += '<td class="itd-td-wide">' + renderCell(ag.confidenceWantToAchieve, ag.wantToAchieve, srcs.wantToAchieve) + '</td>';
        html += '<td class="itd-td-wide">' + renderCell(ag.confidencePainPoint, ag.painPoint, srcs.painPoint) + '</td>';

        // 意思決定者、影響者、情報提供者
        html += '<td class="itd-td-narrow">' + renderCell(ag.confidenceDecisionMaker, ag.decisionMaker, srcs.decisionMaker) + '</td>';
        html += '<td class="itd-td-narrow">' + renderCell(null, ag.influencer, srcs.influencer) + '</td>';
        html += '<td class="itd-td-narrow">' + renderCell(null, ag.informationProvider, srcs.informationProvider) + '</td>';

        // りそな提供価値、つながりうる商品、対応方針
        html += '<td class="itd-td-wide">' + renderCell(ag.confidenceResonaValue, ag.resonaValue, srcs.resonaValue) + '</td>';
        html += '<td class="itd-td-wide">' + renderCell(ag.confidenceRelatedProducts, ag.relatedProducts, srcs.relatedProducts) + '</td>';
        html += '<td class="itd-td-wide">' + renderCell(ag.confidenceActionPlan, ag.actionPlan, srcs.actionPlan) + '</td>';

        html += '</tr>';
      }
    }
    html += '</tbody></table></div></div>';
    return html;
  }

