    var deptGroups = {};
    for (var i = 0; i < keyPersons.length; i++) {
      var kp = keyPersons[i];
      var d = kp.department || '未設定';
      if (!deptGroups[d]) deptGroups[d] = [];
      deptGroups[d].push(kp);
