          (kp.contactStatus ? '<span class="itd-pill itd-pill-contact-' + escHTML(kp.contactStatus) + '">' + escHTML(kp.contactStatus) + '</span>' : '') +
          (kp.influence ? '<span class="itd-pill itd-pill-inf-' + escHTML(kp.influence) + '">影響度' + escHTML(kp.influence) + '</span>' : '') +
          (kp.relationDepth ? '<span class="itd-pill itd-pill-rel">関係' + escHTML(kp.relationDepth) + '</span>' : '') +
