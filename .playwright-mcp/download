    var deptKeys = Object.keys(deptGroups).sort(function(a, b) {
      return departmentRank(a) - departmentRank(b);
    });

    var html = '<div class="itd-kp-intro">' +
      '<strong>キーパーソン構成：</strong>' +
      keyPersons.length + '名（意思決定者 ' +
      keyPersons.filter(function(k){return k.role==='意思決定者'}).length + '名 / 影響者 ' +
      keyPersons.filter(function(k){return k.role==='影響者'}).length + '名 / 情報提供者 ' +
      keyPersons.filter(function(k){return k.role==='情報提供者'}).length + '名）。部署別に整理。カードクリックで詳細表示。' +
    '</div>';

    html += '<div class="itd-kp-deptgroups">';
    for (var k = 0; k < deptKeys.length; k++) {
