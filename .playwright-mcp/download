        '<span class="itd-kp-related-label">関連:</span>';
      for (var i = 0; i < relAgendas.length; i++) {
        html += '<span class="itd-kp-related-pill">' + escHTML(relAgendas[i].minorCategory) + '</span>';
      }
      html += '</div>';
