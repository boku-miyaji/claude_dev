  // PEST分析・Five Forcesはcustomer業界データから生成（本物と同じロジック）
  function renderMacroAnalysis() {
    var trends = customer.industryTrends || '';
    var issues = customer.structuralIssues || '';
    var events = Array.isArray(customer.recentEvents) ? customer.recentEvents.join('') : String(customer.recentEvents || '');
    var allText = trends + issues + events;
    var comp = customer.competitiveInfo || '';

    var factors = [
      { key: 'P', label: 'POLITICAL（政治・法制）', items: [
        /規制|法|薬事|許認可|制度/.test(allText) ? '業界規制・許認可要件の変化' : null,
        /SDGs|ESG|カーボン|サステナ|環境/.test(allText) ? 'ESG/サステナビリティ関連の規制強化' : null,
        /海外|グローバル|為替/.test(allText) ? '海外展開に伴う各国規制・地政学リスク' : null,
      ].filter(Boolean) },
      { key: 'E', label: 'ECONOMIC（経済・市場）', items: [
        /市場.*成長|年率|拡大/.test(trends) ? '対象市場の成長・拡大基調' : null,
        /収益|コスト|投資/.test(issues) ? '収益構造の改善・コスト最適化の必要性' : null,
        /買収|PMI|M&A/.test(allText) ? 'M&A・事業統合に伴う投資と統合コスト' : null,
      ].filter(Boolean) },
      { key: 'S', label: 'SOCIAL（社会・消費）', items: [
        /セルフケア|消費者|健康|ウェルビーイング/.test(trends) ? 'ヘルス/セルフケア需要の高まり' : null,
        /アジア|海外需要/.test(trends) ? 'アジア圏を中心とした海外需要の拡大' : null,
        '消費者ニーズの多様化・デジタルシフト',
      ].filter(Boolean) },
      { key: 'T', label: 'TECHNOLOGY（技術）', items: [
        /DX|デジタル|AI|自動化/.test(allText) ? 'DX・AI活用による業務効率化の進展' : null,
        /再生医療|CDMO|バイオ/.test(allText) ? '先端技術（バイオ・再生医療等）の商業化' : null,
      ].filter(Boolean) },
    ];

    var pestHTML = '<div class="itd-pest-grid">';
    for (var i = 0; i < factors.length; i++) {
      var f = factors[i];
      if (f.items.length === 0) continue;
      pestHTML += '<div class="itd-pest-card itd-pest-' + f.key + '">' +
        '<div class="itd-pest-label">' + escHTML(f.label) + '</div>' +
        '<ul class="itd-pest-list">';
      for (var k = 0; k < f.items.length; k++) {
        pestHTML += '<li>' + escHTML(f.items[k]) + '</li>';
      }
      pestHTML += '</ul></div>';
    }
    pestHTML += '</div>';

    var forces = [
      { label: '業界内の競争', level: comp ? '高' : '中', detail: comp || (customer.industry + '業界における既存プレイヤー間の競争') },
      { label: '新規参入の脅威', level: /参入|新興|異業種/.test(trends + issues) ? '高' : '中', detail: /参入|新興|異業種/.test(trends + issues) ? '新規参入・異業種参入による競争激化' : (customer.industry + '業界への参入障壁は中程度') },
      { label: '買い手の交渉力', level: /株主|投資家|選択と集中/.test(issues) ? '高' : '中', detail: /株主|投資家/.test(issues) ? '株主・投資家からの収益性改善圧力' : '顧客の選択肢多様化による交渉力' },
      { label: '売り手の交渉力', level: /原材料|調達|サプライ/.test(issues + trends) ? '高' : '低', detail: /原材料|調達|サプライ/.test(issues + trends) ? '原材料・サプライチェーンの制約' : '' },
      { label: '代替品の脅威', level: /代替|新技術|破壊的/.test(trends + issues) ? '高' : '低', detail: /代替|新技術|破壊的/.test(trends + issues) ? '新技術・代替サービスによる市場変化' : '' },
    ];
    var forcesHTML = '';
    for (var m = 0; m < forces.length; m++) {
      var fc = forces[m];
      if (!fc.detail) continue;
      forcesHTML += '<div class="itd-force-row">' +
        '<span class="itd-force-level itd-force-level-' + escHTML(fc.level) + '">' + escHTML(fc.level) + '</span>' +
        '<div><span class="itd-force-label">' + escHTML(fc.label) + '</span><span class="itd-force-detail">— ' + escHTML(fc.detail) + '</span></div>' +
      '</div>';
    }

    return '<section class="itd-related-section">' +
      '<h3 class="itd-related-section-title">🌐 マクロ環境分析</h3>' +
      '<div class="itd-info-card">' +
        '<div style="font-size:11px;font-weight:600;color:#15803d;margin-bottom:10px">PEST分析</div>' +
        pestHTML +
      '</div>' +
      '<div class="itd-info-card">' +
        '<div style="font-size:11px;font-weight:600;color:#1d4ed8;margin-bottom:10px">ファイブフォース</div>' +
        forcesHTML +
      '</div>' +
    '</section>';
  }

  // ── キーパーソン組織図 ──
  function renderKeyPersonPanel() {
