.itd-body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans", "Noto Sans JP", "Helvetica Neue", Arial, sans-serif;
  background: #fafafa;
  color: #0f172a;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.itd-topbar {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid #e2e8f0;
  padding: 10px 24px;
}
.itd-topbar-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.itd-brand {
  font-size: 15px;
  font-weight: 700;
  color: #0f172a;
}
.itd-breadcrumb {
  font-size: 13px;
  color: #64748b;
  display: flex;
  align-items: center;
  gap: 6px;
}
.itd-breadcrumb-sep { color: #cbd5e1; }
.itd-breadcrumb-current { color: #0f172a; font-weight: 500; }
.itd-download-badge {
  font-size: 10px;
  padding: 3px 10px;
  border-radius: 4px;
  background: #eff6ff;
  color: #1d4ed8;
  border: 1px solid #bfdbfe;
  font-weight: 500;
}

.itd-tabs {
  position: sticky;
  top: 49px;
  z-index: 30;
  background: #fff;
  border-bottom: 1px solid #e2e8f0;
  padding: 0 24px;
}
.itd-tabs-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  gap: 0;
}
.itd-tab {
  padding: 12px 18px;
  font-size: 13px;
  font-weight: 500;
  color: #64748b;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all 0.15s;
  font-family: inherit;
