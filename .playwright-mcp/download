  // ── モーダル ──
  function openModal(htmlContent) {
    var overlay = document.getElementById('itd-modal-overlay');
    var modal = document.getElementById('itd-modal');
    replaceChildrenFromHTML(modal, htmlContent);
    overlay.classList.add('open');
    modal.scrollTop = 0;
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    var overlay = document.getElementById('itd-modal-overlay');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  function renderAgendaModal(a) {
    var html = '<div class="itd-modal-head">' +
      '<div class="itd-modal-breadcrumb">' +
        escHTML(a.axisLv1) + (a.axisLv2 ? ' › ' + escHTML(a.axisLv2) : '') + ' › ' + escHTML(a.majorCategory) +
      '</div>' +
      '<div class="itd-modal-title-row">' +
        '<h2 class="itd-modal-title">' + escHTML(a.minorCategory) + '</h2>' +
        '<button class="itd-modal-close" data-action="close-modal" aria-label="閉じる">✕</button>' +
      '</div>' +
      '<div style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap">' +
        '<span class="itd-pill itd-imp-' + escHTML(a.importance) + '" style="border:1px solid #e5e7eb">重要度 ' + escHTML(a.importance) + '</span>' +
        '<span class="itd-pill itd-pill-role">' + escHTML(a.phase) + '</span>' +
        '<span class="itd-pill itd-pill-role">理解度 ' + escHTML(a.understanding) + '</span>' +
        '<span class="itd-pill itd-pill-role">ステータス ' + escHTML(a.status) + '</span>' +
      '</div>' +
      (a.importanceRationale ? '<div class="itd-rationale-box">' + escHTML(a.importanceRationale) + '</div>' : '') +
    '</div>';

    html += '<div class="itd-modal-body">';
    html += '<section class="itd-section">' +
      '<h3 class="itd-section-title">' + confDot(a.confidenceWantToAchieve) + '実現したいこと</h3>' +
      '<div class="itd-section-body">' + escHTML(a.wantToAchieveSharp || a.wantToAchieve || '—') + '</div>' +
      (a.wantToAchieveSharp && a.wantToAchieve && a.wantToAchieveSharp !== a.wantToAchieve ?
        '<div class="itd-rationale-box">初期仮説: ' + escHTML(a.wantToAchieve) + '</div>' : '') +
    '</section>';
    html += '<section class="itd-section">' +
      '<h3 class="itd-section-title">' + confDot(a.confidencePainPoint) + 'お困りごと・理由</h3>' +
      '<div class="itd-section-body">' + escHTML(a.painPointSharp || a.painPoint || '—') + '</div>' +
      (a.painPointSharp && a.painPoint && a.painPointSharp !== a.painPoint ?
        '<div class="itd-rationale-box">初期仮説: ' + escHTML(a.painPoint) + '</div>' : '') +
    '</section>';
    html += '<section class="itd-section">' +
      '<h3 class="itd-section-title">' + confDot(a.confidenceResonaValue) + 'りそなの提供価値 / 関連商品</h3>' +
      '<div class="itd-kv-grid">' +
        '<div class="itd-kv-label">提供価値</div><div class="itd-kv-value">' + escHTML(a.resonaValue || '—') + '</div>' +
        '<div class="itd-kv-label">関連商品</div><div class="itd-kv-value">' + confDot(a.confidenceRelatedProducts) + escHTML(a.relatedProducts || '—') + '</div>' +
        (a.resonaTouchpoint ? '<div class="itd-kv-label">りそな接点</div><div class="itd-kv-value">' + escHTML(a.resonaTouchpoint) + '</div>' : '') +
      '</div>' +
    '</section>';

    if (a.solutionCandidates && a.solutionCandidates.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">解決方針候補</h3>' +
        '<div class="itd-solution-list">';
      for (var i = 0; i < a.solutionCandidates.length; i++) {
        var s = a.solutionCandidates[i];
        html += '<div class="itd-solution-card">' +
          '<div class="itd-solution-title">' + escHTML(s.title) + '<span class="itd-solution-fit itd-solution-fit-' + escHTML(s.fit) + '">適合度 ' + escHTML(s.fit) + '</span></div>' +
          '<div class="itd-solution-desc">' + escHTML(s.description) + '</div>' +
          '<div class="itd-solution-rationale">根拠: ' + escHTML(s.rationale) + '</div>' +
        '</div>';
      }
      html += '</div></section>';
    }

    if (a.customerActions && a.customerActions.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">顧客が取りうる打ち手</h3>' +
        '<div class="itd-solution-list">';
      for (var j = 0; j < a.customerActions.length; j++) {
        var c = a.customerActions[j];
        html += '<div class="itd-solution-card">' +
          '<div class="itd-solution-title">' + escHTML(c.title) + '<span class="itd-solution-fit itd-solution-fit-' + escHTML(c.impact) + '">インパクト ' + escHTML(c.impact) + '</span><span class="itd-solution-fit itd-solution-fit-低">' + escHTML(c.timeframe) + '</span></div>' +
          '<div class="itd-solution-desc">' + escHTML(c.description) + '</div>' +
          (c.prerequisites ? '<div class="itd-solution-rationale">前提: ' + escHTML(c.prerequisites) + '</div>' : '') +
        '</div>';
      }
      html += '</div></section>';
    }

    html += '<section class="itd-section">' +
      '<h3 class="itd-section-title">意思決定構造</h3>' +
      '<div class="itd-kv-grid">' +
        '<div class="itd-kv-label">意思決定者</div><div class="itd-kv-value">' + confDot(a.confidenceDecisionMaker) + escHTML(a.decisionMaker || '—') + '</div>' +
        '<div class="itd-kv-label">影響者</div><div class="itd-kv-value">' + escHTML(a.influencer || '—') + '</div>' +
        '<div class="itd-kv-label">情報提供者</div><div class="itd-kv-value">' + escHTML(a.informationProvider || '—') + '</div>' +
      '</div>' +
    '</section>';

    html += '<section class="itd-section">' +
      '<h3 class="itd-section-title">対応方針 / ネクストステップ</h3>' +
      '<div class="itd-kv-grid">' +
        '<div class="itd-kv-label">アクションプラン</div><div class="itd-kv-value">' + confDot(a.confidenceActionPlan) + escHTML(a.actionPlan || '—') + '</div>' +
        '<div class="itd-kv-label">ネクストステップ</div><div class="itd-kv-value">' + confDot(a.confidenceNextStep) + escHTML(a.nextStep || '—') + '</div>' +
      '</div>' +
    '</section>';

    if (a.concerns && a.concerns.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">懸念事項（人が確認すべき点）</h3>' +
        '<ul style="padding-left:20px;margin:0;font-size:13px;color:#1e293b;line-height:1.7">';
      for (var k2 = 0; k2 < a.concerns.length; k2++) {
        var cc = a.concerns[k2];
        html += '<li><strong>' + escHTML(cc.content) + '</strong>' + (cc.reason ? '<div style="color:#64748b;font-size:12px;margin-top:2px">理由: ' + escHTML(cc.reason) + '</div>' : '') + '</li>';
      }
      html += '</ul></section>';
    }

    if (a.discussionPoints && a.discussionPoints.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">論点</h3>' +
        '<ul style="padding-left:20px;margin:0;font-size:13px;color:#1e293b;line-height:1.7">';
      for (var d2 = 0; d2 < a.discussionPoints.length; d2++) {
        html += '<li>' + escHTML(a.discussionPoints[d2]) + '</li>';
      }
      html += '</ul></section>';
    }

    var relatedKPs = [];
    for (var p = 0; p < keyPersons.length; p++) {
      if ((keyPersons[p].relatedAgendaIds || []).indexOf(a.id) !== -1) {
        relatedKPs.push(keyPersons[p]);
      }
    }
    if (relatedKPs.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">関連キーパーソン</h3>' +
        '<div style="display:flex;gap:6px;flex-wrap:wrap">';
      for (var q = 0; q < relatedKPs.length; q++) {
        var rk = relatedKPs[q];
        html += '<span class="itd-related-agenda-pill" data-kp-id="' + escHTML(rk.id) + '">' + escHTML(rk.name) + ' / ' + escHTML(rk.role) + '</span>';
      }
      html += '</div></section>';
    }

    if (a.referenceLinks && a.referenceLinks.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">参照情報</h3>' +
        '<ul class="itd-ref-list">';
      for (var rl = 0; rl < a.referenceLinks.length; rl++) {
        var ref = a.referenceLinks[rl];
        var u = escURL(ref.url);
        html += '<li><span class="itd-ref-type">' + escHTML(ref.type) + '</span>' +
          (u ? '<a href="' + u + '" target="_blank" rel="noopener">' + escHTML(ref.label) + '</a>' : escHTML(ref.label)) +
        '</li>';
      }
      html += '</ul></section>';
    }

    html += '</div>';
    return html;
  }

  function renderKPModal(kp) {
    var relatedAgendas = [];
    var rIds = kp.relatedAgendaIds || [];
    for (var i = 0; i < rIds.length; i++) {
      for (var j = 0; j < agendas.length; j++) {
        if (agendas[j].id === rIds[i]) { relatedAgendas.push(agendas[j]); break; }
      }
    }

    var html = '<div class="itd-modal-head">' +
      '<div class="itd-modal-breadcrumb">' +
        escHTML(customer.name) + ' › キーパーソン › ' + escHTML(kp.role) +
      '</div>' +
      '<div class="itd-modal-title-row">' +
        '<div>' +
          '<h2 class="itd-modal-title">' + escHTML(kp.name) + '</h2>' +
          '<div style="font-size:12px;color:#64748b;margin-top:2px">' + escHTML(kp.title) + (kp.department ? ' ／ ' + escHTML(kp.department) : '') + '</div>' +
        '</div>' +
        '<button class="itd-modal-close" data-action="close-modal" aria-label="閉じる">✕</button>' +
      '</div>' +
      '<div style="display:flex;gap:6px;margin-top:10px;flex-wrap:wrap">' +
        confPill(kp.confidence) +
        '<span class="itd-pill itd-pill-role">' + escHTML(kp.role) + '</span>' +
        (kp.contactStatus ? '<span class="itd-pill itd-pill-contact-' + escHTML(kp.contactStatus) + '">' + escHTML(kp.contactStatus) + '</span>' : '') +
        (kp.influence ? '<span class="itd-pill itd-pill-inf-' + escHTML(kp.influence) + '">影響度' + escHTML(kp.influence) + '</span>' : '') +
        (kp.relationDepth ? '<span class="itd-pill itd-pill-rel">関係' + escHTML(kp.relationDepth) + '</span>' : '') +
      '</div>' +
    '</div>';

    html += '<div class="itd-modal-body">';
    if (kp.memo) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">人物メモ</h3>' +
        '<div class="itd-section-body">' + escHTML(kp.memo) + '</div>' +
      '</section>';
    }
    html += '<section class="itd-section">' +
      '<h3 class="itd-section-title">基本情報</h3>' +
      '<div class="itd-kv-grid">' +
        '<div class="itd-kv-label">役割</div><div class="itd-kv-value">' + escHTML(kp.role) + '</div>' +
        (kp.company ? '<div class="itd-kv-label">所属企業</div><div class="itd-kv-value">' + escHTML(kp.company) + '</div>' : '') +
        (kp.department ? '<div class="itd-kv-label">部署</div><div class="itd-kv-value">' + escHTML(kp.department) + '</div>' : '') +
        (kp.contactStatus ? '<div class="itd-kv-label">接触状況</div><div class="itd-kv-value">' + escHTML(kp.contactStatus) + '</div>' : '') +
        (kp.influence ? '<div class="itd-kv-label">影響度</div><div class="itd-kv-value">' + escHTML(kp.influence) + '</div>' : '') +
        (kp.lastMeetingDate ? '<div class="itd-kv-label">最終面談</div><div class="itd-kv-value">' + escHTML(kp.lastMeetingDate) + '</div>' : '') +
      '</div>' +
    '</section>';

    if (kp.talkableTopics && kp.talkableTopics.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">話せるテーマ</h3>' +
        '<div style="display:flex;gap:6px;flex-wrap:wrap">';
      for (var tt = 0; tt < kp.talkableTopics.length; tt++) {
        html += '<span class="itd-kp-related-pill">' + escHTML(kp.talkableTopics[tt]) + '</span>';
      }
      html += '</div></section>';
    }

    if (kp.blockerRisk) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">ブロッカーリスク</h3>' +
        '<div class="itd-rationale-box">' + escHTML(kp.blockerRisk) + '</div>' +
      '</section>';
    }

    if (relatedAgendas.length) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">関連アジェンダ（' + relatedAgendas.length + '件）</h3>' +
        '<div class="itd-solution-list">';
      for (var ra = 0; ra < relatedAgendas.length; ra++) {
        var ag = relatedAgendas[ra];
        html += '<div class="itd-solution-card" data-agenda-id="' + escHTML(ag.id) + '" style="cursor:pointer">' +
          '<div class="itd-solution-title">' +
            '<span class="itd-pill itd-pill-role">' + escHTML(ag.axisLv1) + '</span>' +
            escHTML(ag.minorCategory) +
            '<span class="itd-pill itd-imp-' + escHTML(ag.importance) + '" style="border:1px solid #e5e7eb">重要度 ' + escHTML(ag.importance) + '</span>' +
          '</div>' +
          '<div class="itd-solution-desc">' + escHTML(ag.wantToAchieveSharp || ag.wantToAchieve || '') + '</div>' +
        '</div>';
      }
      html += '</div></section>';
    }

    if (kp.source) {
      html += '<section class="itd-section">' +
        '<h3 class="itd-section-title">推定根拠</h3>' +
        '<div class="itd-section-body">' + escHTML(kp.source);
      if (kp.sourceRef) {
        var u2 = escURL(kp.sourceRef);
        if (u2) html += ' <a href="' + u2 + '" target="_blank" rel="noopener" style="color:#2563eb">↗</a>';
      }
      html += '</div></section>';
    }

    html += '</div>';
    return html;
  }

  function setupEvents() {
    document.querySelectorAll('.itd-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = tab.getAttribute('data-tab');
        document.querySelectorAll('.itd-tab').forEach(function(t) {
          t.classList.toggle('active', t === tab);
        });
        document.querySelectorAll('.itd-panel').forEach(function(p) {
          p.hidden = p.getAttribute('data-panel') !== target;
        });
      });
    });

    document.body.addEventListener('click', function(e) {
      var target = e.target;
      if (!(target instanceof Element)) return;

      if (target.closest('[data-action="close-modal"]')) { closeModal(); return; }
      if (target.id === 'itd-modal-overlay') { closeModal(); return; }

      var agendaEl = target.closest('[data-agenda-id]');
      if (agendaEl) {
        var aid = agendaEl.getAttribute('data-agenda-id');
        for (var i = 0; i < agendas.length; i++) {
          if (agendas[i].id === aid) { openModal(renderAgendaModal(agendas[i])); return; }
        }
        return;
      }

      var kpEl = target.closest('[data-kp-id]');
      if (kpEl) {
        var kid = kpEl.getAttribute('data-kp-id');
        for (var j = 0; j < keyPersons.length; j++) {
          if (keyPersons[j].id === kid) { openModal(renderKPModal(keyPersons[j])); return; }
        }
        return;
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });
  }

  renderLayout();
  setupEvents();
})();

</script>
</body>
</html>