  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/prompt-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "^/company",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/company-pull.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/permission-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/auto-pull.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/session-start-marker.sh"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/supabase-status.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/config-sync.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/doc-freshness-check.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/auto-push.sh"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/session-summary.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/pre-compact-save.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/post-compact-restore.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/post-edit-check.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/artifact-auto-sync.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/claude-md-size-guard.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/docs-sync-guard.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/tool-collector.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "company@ai-company": true
  },
  "extraKnownMarketplaces": {
    "ai-company": {
      "source": {
        "source": "github",
        "repo": "boku-miyaji/claude_dev",
        "path": "."
      }
    }
  },
  "skipDangerousModePermissionPrompt": false
}
