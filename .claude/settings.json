{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "30000",
    "CLAUDE_CODE_DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "// --- Shell: general tools ---",
      "Bash(python3:*)",
      "Bash(python3 -c \":*)",
      "Bash(python:*)",
      "Bash(python -c:*)",
      "Bash(node:*)",
      "Bash(node -e \":*)",
      "Bash(timeout:*)",
      "Bash(wc:*)",
      "Bash(pgrep:*)",
      "Bash(pkill:*)",
      "Bash(kill:*)",
      "Bash(lsof:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(xargs:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(dd:*)",
      "Bash(env)",
      "Bash(chmod:*)",
      "Bash(fuser:*)",
      "Bash(xxd:*)",
      "Bash(shasum:*)",
      "Bash(set -a)",
      "Bash(set +a)",
      "Bash(source:*)",
      "Bash(for dir:*)",
      "Bash(sqlite3:*)",
      "// --- Package managers ---",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(uv:*)",
      "Bash(conda:*)",
      "Bash(apt-get:*)",
      "Bash(apt-cache:*)",
      "Bash(apt list:*)",
      "Bash(dpkg -l:*)",
      "// --- Git (portable patterns) ---",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git clone:*)",
      "Bash(git submodule:*)",
      "Bash(git revert:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git rm:*)",
      "Bash(git remote:*)",
      "Bash(git check-ignore:*)",
      "Bash(git hash-object:*)",
      "Bash(git update-index:*)",
      "Bash(git rev-parse:*)",
      "Bash(git version:*)",
      "Bash(git config:*)",
      "Bash(git -C:*)",
      "Bash(gh pr:*)",
      "Bash(GIT_TRACE=1 git:*)",
      "// --- Docker ---",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(/usr/bin/docker compose:*)",
      "Bash(docker compose exec:*)",
      "// --- Build & test ---",
      "Bash(pytest:*)",
      "Bash(npx tsc:*)",
      "// --- GPU monitoring ---",
      "Bash(nvidia-smi:*)",
      "// --- Read (portable paths) ---",
      "Read(//workspace/**)",
      "Read(//tmp/**)",
      "Read(//dev/**)",
      "Read(//usr/**)",
      "// --- Web ---",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:docs.kicad.org)",
      "WebFetch(domain:dev-docs.kicad.org)",
      "WebFetch(domain:forum.kicad.info)",
      "WebFetch(domain:www.notion.so)",
      "WebFetch(domain:platform.openai.com)",
      "// --- MCP plugins ---",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_serena_serena__activate_project",
      "mcp__plugin_serena_serena__check_onboarding_performed",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__search_for_pattern",
      "mcp__plugin_serena_serena__find_symbol",
      "mcp__plugin_serena_serena__find_file",
      "mcp__plugin_serena_serena__read_file",
      "mcp__plugin_serena_serena__create_text_file",
      "mcp__plugin_serena_serena__replace_content",
      "mcp__plugin_serena_serena__replace_symbol_body",
      "mcp__plugin_serena_serena__insert_after_symbol",
      "mcp__plugin_serena_serena__get_symbols_overview",
      "mcp__plugin_serena_serena__write_memory",
      "mcp__plugin_serena_serena__list_memories",
      "mcp__plugin_serena_serena__think_about_collected_information",
      "mcp__plugin_serena_serena__think_about_whether_you_are_done",
      "mcp__playwright",
      "// --- Skills ---",
      "Skill(design-principles)",
      "Skill(design-principles:*)",
      "Skill(document-skills:xlsx)",
      "WebFetch(domain:www.cse.cuhk.edu.hk)",
      "WebFetch(domain:par.nsf.gov)",
      "WebFetch(domain:www.industrialmind.ai)",
      "WebFetch(domain:www.researchgate.net)",
      "WebFetch(domain:www.sciencedirect.com)",
      "WebFetch(domain:ams-net.github.io)",
      "WebFetch(domain:paperswithcode.com)",
      "WebFetch(domain:shipxu123.github.io)",
      "Read(//workspace/=== marketplaces/**)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:opencode.ai)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:sesamedisk.com)",
      "WebFetch(domain:danielmiessler.com)",
      "WebFetch(domain:dev.to)",
      "Bash(supabase --version)",
      "Bash(supabase projects:*)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:pecollective.com)",
      "Bash(/tmp/check_departments.sh:*)",
      "Bash(/tmp/check_companies.sh:*)",
      "Bash(/tmp/final_check.sh:*)",
      "Bash(/tmp/qa_check.sh:*)",
      "Bash(/tmp/complete_check.sh:*)",
      "Bash(find /workspace/.company -type f \\\\\\(-name *.json -o -name *.md -o -name *.txt -o -name *.yaml -o -name *.yml \\\\\\))",
      "Read(//workspace/{gsub\\(/ /**)",
      "Read(//^\\\\|[[:space:]]+[a-z]/ && !/ID/ {gsub\\(/[[:space:]]/**)",
      "Bash(bash /workspace/.claude/hooks/freshness-check.sh)",
      "Bash(/tmp/extract_render_functions.sh)",
      "Bash(mkdir -p public)",
      "Bash(cp index.legacy.html public/index.legacy.html)",
      "Bash(vercel --version)",
      "Bash(sed -i \"s/\\\\.insert\\({action:'intelligence_collect', details:{/\\\\.insert\\({action:'intelligence_collect', metadata:{/g\" legacy.ts)",
      "Bash(sed -i \"s/\\\\.insert\\({action:'intelligence_item', details:{/\\\\.insert\\({action:'intelligence_item', metadata:{/g\" legacy.ts)",
      "Read(//home/node/.claude/plugins/**)",
      "Bash(cp /home/node/.claude/plugins/marketplaces/ai-company/skills/company/SKILL.md /home/node/.claude/plugins/cache/ai-company/company/1.0.0/skills/company/SKILL.md)",
      "Bash(cp /home/node/.claude/plugins/marketplaces/ai-company/skills/company/SKILL.md /home/node/.claude/plugins/marketplaces/ai-company/plugins/company/skills/company/SKILL.md)"
    ],
    "additionalDirectories": [
      "/home/node/.claude/plugins/cache/ai-company/company/1.0.0",
      "/home/node/.claude/plugins/cache/ai-company/company/1.0.0/.claude-plugin",
      "/home/node/.claude/plugins/marketplaces/ai-company/.claude-plugin",
      "/home/node/.claude/knowledge",
      "/workspace/.company/departments/security",
      "/workspace/.claude/hooks",
      "/workspace/.company-polaris/secretary",
      "/tmp",
      "/home/node/.claude/plugins/marketplaces/ai-company/skills/company"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/prompt-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "^/company",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/company-pull.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/permission-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/auto-pull.sh"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/session-start-marker.sh"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/supabase-status.sh"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/config-sync.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/auto-push.sh"
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/session-summary.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/post-edit-check.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/artifact-auto-sync.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/tool-collector.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "company@ai-company": true
  },
  "extraKnownMarketplaces": {
    "ai-company": {
      "source": {
        "source": "github",
        "repo": "boku-miyaji/claude_dev",
        "path": "."
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
