{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "30000",
    "CLAUDE_CODE_DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(docker compose:*)",
      "Read(//tmp/**)",
      "Bash(wc:*)",
      "Bash(pgrep:*)",
      "Bash(dd:*)",
      "WebFetch(domain:github.com)",
      "Bash(npx google-calendar-mcp:*)",
      "Bash(npm info:*)",
      "Bash(npx -y google-calendar-mcp --help)",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(git rebase:*)",
      "Read(//home/node/**)",
      "Bash(CLAUDE_PROJECT_DIR=\"/workspace\" bash /workspace/.claude/hooks/config-sync.sh)",
      "Bash(git clone:*)",
      "Bash(pip3 --version)",
      "Bash(wget -q https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O /tmp/miniconda.sh)",
      "Bash(bash /tmp/miniconda.sh -b -p $HOME/miniconda3)",
      "Bash(rm /tmp/miniconda.sh)",
      "Read(//home/yutamiyaji/development/polaris/claude_dev/**)",
      "Bash(python3 -c \":*)",
      "Bash(nvidia-smi --query-gpu=utilization.gpu,memory.used,memory.total --format=csv,noheader)",
      "Bash(nvidia-smi --query-gpu=utilization.gpu,memory.used --format=csv,noheader)",
      "Bash(ps -p 1308529 -o pid,pcpu,pmem,etime --no-headers)",
      "Bash(ps -p 1308529 -o pid,pcpu,etime --no-headers)",
      "Bash(conda run -n cktgen python3 -c \":*)",
      "Bash(conda activate:*)",
      "Bash(nvidia-smi --query-compute-apps=pid,name,used_memory --format=csv)",
      "Bash(nvidia-smi --query-compute-apps=pid,used_memory --format=csv,noheader)",
      "Bash(nvidia-smi --query-compute-apps=pid,name,used_memory --format=csv,noheader)",
      "Bash(nvidia-smi --query-gpu=memory.total,memory.used,memory.free --format=csv,noheader)",
      "Bash(ps -p 2094000 -o pid,pcpu,etime --no-headers)",
      "Bash(ps -p 2080809 -o pid,pcpu,etime --no-headers)",
      "Bash(ps -p 2166728 -o pid,pcpu,etime --no-headers)",
      "Bash(nvidia-smi --query-gpu=memory.used,memory.free --format=csv,noheader)",
      "Bash(set -a)",
      "Bash(set +a)",
      "Bash(for dir:*)",
      "Read(//workspace/**)",
      "Bash(mv /workspace/.company-rikyu/ai-dev/design/*.md /workspace/.company-rikyu/secretary/archive/)",
      "Bash(mv /workspace/.company-rikyu/materials/deliverables/*.md /workspace/.company-rikyu/secretary/archive/)",
      "Bash(git -C /workspace stash pop)",
      "Bash(git submodule:*)",
      "Bash(git -C /workspace remote -v)",
      "Bash(cp /workspace/plugins/company/.claude-plugin/marketplace.json /home/node/.claude/plugins/cache/ai-company/company/1.0.0/.claude-plugin/marketplace.json)",
      "Bash(rm /home/node/.claude/plugins/cache/ai-company/company/1.0.0/.claude-plugin/plugin.json)",
      "Bash(git -C /workspace check-ignore .company/)",
      "Bash(git -C /workspace ls-files .company/)",
      "Bash(npx next:*)",
      "Read(//dev/**)",
      "Bash(shasum -a 256)",
      "WebFetch(domain:www.notion.so)",
      "Bash(rm -f .next/dev/lock)",
      "Bash(pnpm dev:*)",
      "Bash(node -e \":*)",
      "Bash(git hash-object:*)",
      "Bash(git update-index:*)",
      "Read(//workspace/$dir/secretary/**)",
      "Bash(git -C /workspace log --oneline -5)"
    ],
    "additionalDirectories": [
      "/home/yutamiyaji/development/polaris/claude_dev/circuit_diagram/gnn_verification/step1_cktgen/CktGNN/OCB/CktBench101",
      "/workspace/circuit_diagram/gnn_verification",
      "/home/node/.claude/plugins/cache/ai-company/company/1.0.0/skills/company/references",
      "/workspace/project-rikyu-sales-proposals-poc/server/.next/dev",
      "/workspace/project-scotch-care/reference_docs/RFI/回答"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prompt-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "^/company",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/company-pull.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/permission-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start-marker.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/supabase-status.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/config-sync.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-summary.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-check.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "company@ai-company": true
  },
  "extraKnownMarketplaces": {
    "ai-company": {
      "source": {
        "source": "github",
        "repo": "boku-miyaji/claude_dev",
        "path": "/workspace"
      }
    }
  }
}
