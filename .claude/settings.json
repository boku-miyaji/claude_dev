{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "30000",
    "CLAUDE_CODE_DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(/workspace/circuit_diagram/backend/.venv/bin/python:*)",
      "Bash(docker compose:*)",
      "Bash(git -C /workspace/circuit_diagram show HEAD:backend/src/routers/block_diagram.py)",
      "Bash(git -C /workspace/circuit_diagram show HEAD:backend/src/prompts/__init__.py)",
      "Read(//tmp/**)",
      "Bash(wc:*)",
      "Bash(pgrep:*)",
      "Bash(dd:*)",
      "Read(//home/node/.claude/plugins/cache/ai-company/company/1.0.0/skills/company/references/**)",
      "WebFetch(domain:github.com)",
      "Read(//home/node/.npm/_npx/7145db6b471ecd40/node_modules/google-calendar-mcp/dist/**)",
      "Bash(npx google-calendar-mcp:*)",
      "Bash(npm info:*)",
      "Bash(npx -y google-calendar-mcp --help)",
      "Read(//home/node/.npm/_npx/**)",
      "Read(//home/node/**)",
      "Bash(git -C /workspace/diary diff --stat)",
      "Bash(git -C /workspace/diary log --oneline -3)",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(git rebase:*)"
    ],
    "additionalDirectories": [
      "/workspace/circuit_diagram/frontend/src/app/projects/[projectId]",
      "/workspace/circuit_diagram/frontend/src/app/projects/[projectId]/workspace",
      "/workspace/circuit_diagram/frontend/src/app/projects/*/block-diagram",
      "/workspace/circuit_diagram/backend/src/routers/__pycache__",
      "/workspace/output",
      "/workspace/.claude"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/prompt-log.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/permission-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/workspace/.claude/hooks/config-sync.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "company@ai-company": true
  },
  "extraKnownMarketplaces": {
    "ai-company": {
      "source": {
        "source": "github",
        "repo": "boku-miyaji/claude_dev",
        "path": "/workspace"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1755317418565
  }
}
