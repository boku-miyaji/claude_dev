# Supabase connection for company-dashboard hooks
# Copy to supabase.env and fill in values:
#   cp supabase.env.example supabase.env

SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Ingest API Key for RLS header check (migration-015)
# Generate: SELECT gen_random_uuid(); in Supabase SQL Editor
# Then: ALTER DATABASE postgres SET app.ingest_api_key = '<value>';
SUPABASE_INGEST_KEY="your-ingest-key"
